_create_ssh_notify_file(){
  cat >> "/etc/profile.d/ssh-notify.sh" << END
#!/bin/sh

USERID="$TELEGRAM_ID"
KEY="$TELEGRAM_TOKEN"

TIMEOUT="10"
URL="https://api.telegram.org/bot\$KEY/sendMessage"
DATE_EXEC="\$(date "+%d %b %Y %H:%M")"
if [ -n "\$SSH_CLIENT" ]; then
  IP=\$(echo "\$SSH_CLIENT" | awk '{print \$1}')
  PORT=\$(echo "\$SSH_CLIENT" | awk '{print \$3}')
  HOSTNAME=\$(hostname -f)
  IPADDR=\$(hostname -I | awk '{print \$1}')
  # mktemp: ten ngau nhien, quyen 600. Truoc day dung duong dan CO DINH
  # /tmp/ipinfo-\$DATE_EXEC.txt (nhay don nen \$DATE_EXEC khong he duoc thay the)
  # -> user thuong doan duoc, tao san symlink tro toi file he thong, root chay
  # "curl -o" se ghi de file do. Day la duong leo quyen.
  TMPFILE=\$(mktemp /tmp/ipinfo.XXXXXXXXXX) || exit 0
  # https + khong doi hoi ipinfo tra loi duoc: mat mang thi bo qua phan vi tri
  curl -fsS --max-time "\$TIMEOUT" "https://ipinfo.io/\$IP" -o "\$TMPFILE" 2>/dev/null
  CITY=\$(jq -r '.city // empty' "\$TMPFILE" 2>/dev/null)
  REGION=\$(jq -r '.region // empty' "\$TMPFILE" 2>/dev/null)
  COUNTRY=\$(jq -r '.country // empty' "\$TMPFILE" 2>/dev/null)
  ORG=\$(jq -r '.org // empty' "\$TMPFILE" 2>/dev/null)
  TEXT="\$DATE_EXEC: \${USER} logged in to \$HOSTNAME (\$IPADDR) from \$IP - \$ORG - \$CITY, \$REGION, \$COUNTRY on port \$PORT"
  curl -s --max-time "\$TIMEOUT" -d "chat_id=\$USERID&disable_web_page_preview=1&text=\$TEXT" "\$URL" > /dev/null
  rm -f "\$TMPFILE"
fi
END
}

_run(){
    if [ -f /etc/profile.d/ssh-notify.sh ]; then
        ALERT=$(printf "%s" "${RED}Ban da tao SSH Notify roi.${NC}")
    else
        read -r -p "Nhap vao Telegram Chat ID: " TELEGRAM_ID
        read -r -p "Nhap vao Telegram Token: " TELEGRAM_TOKEN

        if [ -z "$TELEGRAM_ID" ]; then
            ALERT=$(printf "%s" "${RED}Ban chua nhap Telegram ID.${NC}")
        fi

        if [ -z "$TELEGRAM_TOKEN" ]; then
            ALERT=$(printf "%s" "${RED}Ban chua nhap Telegram Token.${NC}")
        fi
    fi

    if [ -z "$ALERT" ]; then
        if [ ! -f /usr/bin/jq ]; then
            apt update -y && apt install jq -y
            clear
        fi
        _create_ssh_notify_file
        clear
        printf "%s\n" "${GREEN}Tao SSH Notify thanh cong.${NC}"
    else
        clear
        printf "%s\n" "$ALERT"
    fi
}

ALERT=''
TELEGRAM_ID=''
TELEGRAM_TOKEN=''

_run
telegram_notify
