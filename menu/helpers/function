# --------------------------------------------------------------------------- #
# So muc luc backup
#
# Vi sao can: co gateway S3 khong ho tro tham so 'prefix' cua ListObjectsV2 —
# doc file theo duong dan chinh xac thi duoc, nhung liet ke thu muc con LUON
# tra ve rong. Restore cua hostvn von dua vao "rclone lsf" de hien danh sach
# ngay/domain, nen voi loai remote do se bao "khong co backup" du du lieu van
# nam nguyen tren server.
#
# Cach giai: moi lan backup thi ghi lai DA LUU GI O DAU. So muc luc nay dat
# ca o may (/var/hostvn/.backup_index.<remote>) lan tren remote o duong dan
# CO DINH <IP>/backup_index.txt — doc duoc bang copyto ma khong can liet ke,
# nen cai lai VPS van khoi phuc duoc.
#
# Moi dong: <ngay>|<domain>|<file1>,<file2>
# --------------------------------------------------------------------------- #
_bk_index_file() {
    echo "/var/hostvn/.backup_index.${1}"
}

_bk_index_remote_path() {
    # Dat o GOC remote, khong long trong <IP>/. Ly do: co gateway S3 khong xu ly
    # duoc ghi de vao mot duong dan nam sau nhieu cap prefix ("destination is a
    # file"), trong khi ghi/doc o goc thi binh thuong. Ten co kem IP nen nhieu
    # may cung day vao mot bucket van khong dam nhau.
    echo "${1}:hostvn_backup_index_${IPADDRESS}.txt"
}

# Ghi nhan mot ban backup vua day len remote, roi dong bo muc luc len do luon
backup_index_add() {
    local remote="$1" bdate="$2" bdomain="$3" bdir="$4" idx files tmp
    [ -z "${remote}" ] && return 0
    idx=$(_bk_index_file "${remote}")
    files=$(cd "${bdir}" 2>/dev/null && ls -1A 2>/dev/null | tr '\n' ',' | sed 's/,$//')
    [ -z "${files}" ] && return 0

    touch "${idx}"; chmod 600 "${idx}"
    tmp=$(mktemp) || return 0
    grep -v "^${bdate}|${bdomain}|" "${idx}" > "${tmp}" 2>/dev/null
    echo "${bdate}|${bdomain}|${files}" >> "${tmp}"
    sort -ru "${tmp}" -o "${idx}"
    rm -f "${tmp}"

    # Xoa TRUOC roi moi ghi. Co gateway S3 chi cho ghi mot lan vao mot duong
    # dan: ghi de bao "is a file not a directory", nhung xoa xong ghi lai thi
    # binh thuong. Voi remote thuong thi deletefile chi la thao tac thua vo hai.
    local rpath
    rpath=$(_bk_index_remote_path "${remote}")
    rclone deletefile "${rpath}" >/dev/null 2>&1
    # copyto: ghi vao DUNG duong dan, khong can liet ke thu muc
    rclone copyto "${idx}" "${rpath}" >/dev/null 2>&1
}

# Lay muc luc tu remote ve va gop voi ban o may
backup_index_fetch() {
    local remote="$1" idx tmp
    [ -z "${remote}" ] && return 0
    idx=$(_bk_index_file "${remote}")
    tmp="${idx}.remote"
    rm -f "${tmp}"
    rclone copyto "$(_bk_index_remote_path "${remote}")" "${tmp}" >/dev/null 2>&1
    if [ -s "${tmp}" ]; then
        touch "${idx}"
        cat "${idx}" "${tmp}" 2>/dev/null | grep -E '^[^|]+\|[^|]+\|' | sort -ru -o "${idx}"
        chmod 600 "${idx}"
    fi
    rm -f "${tmp}"
    [ -s "${idx}" ]
}

backup_index_dates() {
    cut -d'|' -f1 "$(_bk_index_file "$1")" 2>/dev/null | sort -ru
}

backup_index_domains() {
    grep "^${2}|" "$(_bk_index_file "$1")" 2>/dev/null | cut -d'|' -f2 | sort -u
}

backup_index_files() {
    grep "^${2}|${3}|" "$(_bk_index_file "$1")" 2>/dev/null | cut -d'|' -f3 | tr ',' '\n' | grep -v '^$'
}

# Remote co liet ke duoc theo prefix khong (mot lan cho moi phien)
remote_can_list() {
    local remote="$1" base="$2"
    [ -n "$(rclone lsf "${remote}:${base}" 2>/dev/null)" ]
}

# Day mot thu muc backup len remote, chiu duoc gateway "chi cho ghi mot lan".
#
# "rclone copy <thu_muc>" that bai voi loai gateway do khi duong dan da ton tai
# ("is a file not a directory"), ma xoa ca thu muc thi lai can liet ke — thu
# cung khong duoc ho tro. Nen day theo TUNG FILE: xoa dung file do roi ghi lai.
backup_upload_dir() {
    local remote="$1" bdate="$2" bdomain="$3" bdir="$4" f sent=0 total=0
    [ -z "${remote}" ] && return 1
    for f in "${bdir}"/*; do
        [ -f "${f}" ] || continue
        total=$((total + 1))
        rclone deletefile "${remote}:${IPADDRESS}/${bdate}/${bdomain}/$(basename "${f}")" >/dev/null 2>&1
        if rclone copyto "${f}" "${remote}:${IPADDRESS}/${bdate}/${bdomain}/$(basename "${f}")"                 --bwlimit 30M >> /var/log/rclone.log 2>&1; then
            sent=$((sent + 1))
        fi
    done
    [ "${total}" -gt 0 ] && [ "${sent}" -eq "${total}" ]
}

# Liet ke remote cloud da ket noi kem kieu va dich den.
# An remote tho "<ten>-s3": no la phan ky thuat cua ket noi S3, nguoi dung chi
# can biet alias "<ten>" tro vao bucket nao.
list_cloud_remotes() {
    local r t tgt bucket
    mapfile -t _all < <(rclone listremotes 2>/dev/null)
    for r in "${_all[@]}"; do
        r=${r%:}
        [ -z "${r}" ] && continue
        [[ "${r}" == *-s3 ]] && continue
        t=$(rclone config show "${r}" 2>/dev/null | grep -m1 '^type' | cut -d= -f2 | tr -d ' ')
        tgt=$(rclone config show "${r}" 2>/dev/null | grep -m1 '^remote' | cut -d= -f2 | tr -d ' ')
        if [ "${t}" = "alias" ] && [[ "${tgt}" == *-s3:* ]]; then
            bucket=${tgt#*:}
            printf '%s|S3|bucket: %s\n' "${r}" "${bucket}"
        else
            printf '%s|%s|%s\n' "${r}" "${t:-?}" "${tgt}"
        fi
    done
}

# Xoa TRIET DE mot ket noi cloud: alias + remote tho di kem + so muc luc.
# Chi xoa alias thi remote tho "<ten>-s3" o lai mo coi trong rclone.conf.
delete_cloud_remote() {
    local name="$1"
    [ -z "${name}" ] && return 1
    rclone config delete "${name}" >/dev/null 2>&1
    if rclone listremotes 2>/dev/null | grep -qx "${name}-s3:"; then
        rclone config delete "${name}-s3" >/dev/null 2>&1
    fi
    rm -f "/var/hostvn/.backup_index.${name}"
    ! rclone listremotes 2>/dev/null | grep -qx "${name}:"
}
