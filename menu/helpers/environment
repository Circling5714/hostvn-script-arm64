#!/bin/bash

######################################################################
#      HostVN ARM64 - Environment detection & service abstraction    #
#                                                                    #
#  Cho phep HostVN chay tren:                                        #
#   - VPS/container co systemd (dung systemctl nhu binh thuong)      #
#   - chroot/Linux Deploy/Android khong systemd (quan ly truc tiep)  #
######################################################################

# ---------------------------------------------------------------
# Phat hien moi truong (chay 1 lan, cache qua bien HOSTVN_*)
# ---------------------------------------------------------------
_hostvn_detect_env() {
    HOSTVN_ARCH="$(uname -m 2>/dev/null)"   # aarch64 | x86_64 | armv7l...

    # Init system: coi la systemd chi khi PID1 la systemd VA systemctl dung duoc
    if command -v systemctl >/dev/null 2>&1 && [ "$(cat /proc/1/comm 2>/dev/null)" = "systemd" ]; then
        HOSTVN_INIT="systemd"
    else
        HOSTVN_INIT="manual"
    fi

    # Android (Linux Deploy expose /system, mount /sdcard)?
    if [ -d /system/bin ] || grep -qa '/sdcard' /proc/mounts 2>/dev/null; then
        HOSTVN_ANDROID="yes"
    else
        HOSTVN_ANDROID="no"
    fi

    # chroot/container?
    if [ "${HOSTVN_INIT}" = "manual" ] || [ "${HOSTVN_ANDROID}" = "yes" ]; then
        HOSTVN_CONTAINER="yes"
    else
        HOSTVN_CONTAINER="no"
    fi

    # Firewall (iptables) kha dung? (chroot tren Android thuong khong co netfilter)
    if command -v iptables >/dev/null 2>&1 && iptables -L -n >/dev/null 2>&1; then
        HOSTVN_FIREWALL="yes"
    else
        HOSTVN_FIREWALL="no"
    fi

    # eatmydata (libeatmydata): bien fsync/fdatasync/sync/msync thanh no-op qua LD_PRELOAD.
    # BAT BUOC tren Android: storage cua container la file loop tren /data (ext4) da qua
    # lop ma hoa (dm-crypt/FBE) do 'vold' quan ly. Bao ghi lien tuc cua InnoDB (redo log,
    # checkpoint flush, doublewrite) lam nghen I/O -> watchdog cua vold het gio -> Android
    # reboot (getprop ro.boot.bootreason = "reboot,vold-failed"). Khu fsync bang eatmydata
    # loai bo cac cu dinh tre dong bo nay. Da kiem chung: ghi 3.2 trieu dong InnoDB lien
    # tuc duoi eatmydata KHONG con reboot.
    HOSTVN_EATMYDATA=""
    if [ "${HOSTVN_ANDROID}" = "yes" ]; then
        for _emd in /usr/lib/*/libeatmydata.so.1 /usr/lib/libeatmydata.so.1 \
                    /usr/lib/*/libeatmydata.so /usr/lib/libeatmydata.so; do
            [ -e "${_emd}" ] && { HOSTVN_EATMYDATA="${_emd}"; break; }
        done
    fi

    export HOSTVN_ARCH HOSTVN_INIT HOSTVN_ANDROID HOSTVN_CONTAINER HOSTVN_FIREWALL HOSTVN_EATMYDATA
}

# ---------------------------------------------------------------
# Giam ap luc I/O len storage ma hoa (vold) tren Android de tranh
# reboot "reboot,vold-failed". Ba lop bo tro nhau:
#   1) nobarrier  - chan barrier/FLUSH cua ext4 JOURNAL xuong lop dm-crypt.
#                   Day la cho eatmydata KHONG voi toi (barrier do kernel phat,
#                   khong phai fsync ung dung) - la nguyen nhan reboot khi tao/xoa
#                   nhieu file (composer, wp package install, giai nen...).
#   2) vm.dirty_* thap - ep writeback nho giot thay vi don ~1GB roi flush cuc lon
#                   (mac dinh dirty_ratio=20% lam nghen I/O ma hoa -> vold het gio).
#   3) eatmydata (o _svc mariadb) - khu fsync ung dung cua InnoDB.
# Da kiem chung: 3 vong tao+xoa 30k file + dd 2GB duoi bo ba nay KHONG reboot.
# Ap dung lai moi lan source vi mount/sysctl reset sau khi container remount/boot.
_hostvn_harden_android_io() {
    [ "${HOSTVN_ANDROID}" = "yes" ] || return 0

    # 1) nobarrier cho ext4 goc cua container (neu la loop device va chua bat)
    local rootdev
    rootdev=$(awk '$2=="/"{print $1; exit}' /proc/mounts 2>/dev/null)
    case "${rootdev}" in
        /dev/block/loop*|/dev/loop*)
            if ! grep -q '^[^ ]* / ext4 [^ ]*nobarrier' /proc/mounts 2>/dev/null; then
                mount -o remount,nobarrier / 2>/dev/null
            fi ;;
    esac

    # 2) Throttle dirty pages (chi khi ghi duoc /proc/sys/vm)
    if [ -w /proc/sys/vm/dirty_bytes ]; then
        echo 4194304 > /proc/sys/vm/dirty_background_bytes 2>/dev/null   # 4MB
        echo 8388608 > /proc/sys/vm/dirty_bytes 2>/dev/null             # 8MB
        echo 300     > /proc/sys/vm/dirty_expire_centisecs 2>/dev/null  # 3s
        echo 100     > /proc/sys/vm/dirty_writeback_centisecs 2>/dev/null # 1s
    fi

    # 3) Luoi an toan OOM: dat oom_score_adj=1000 cho tien trinh nay (va cac con ke thua).
    #    Neu he thong het RAM, kernel/lmkd se giet tien trinh CUA container (cai dat / dich
    #    vu - phuc hoi duoc) TRUOC, thay vi giet 'vold' (score rat thap) -> tranh reboot.
    [ -w /proc/self/oom_score_adj ] && echo 1000 > /proc/self/oom_score_adj 2>/dev/null

    # 4) dpkg khong fsync (force-unsafe-io): pha cai goi (apt/dpkg) trong script 'ubuntu'
    #    KHONG duoc bao boi eatmydata (chi hostvn.run duoc bao). dpkg fsync moi goi khi
    #    cai 300+ goi -> nghen vold -> reboot. force-unsafe-io khu fsync cho MOI dpkg.
    if [ -d /etc/dpkg/dpkg.cfg.d ] && [ ! -f /etc/dpkg/dpkg.cfg.d/hostvn-unsafe-io ]; then
        echo 'force-unsafe-io' > /etc/dpkg/dpkg.cfg.d/hostvn-unsafe-io 2>/dev/null
    fi
}

# ---------------------------------------------------------------
# MariaDB datadir tren tmpfs (RAM) cho Android - fix reboot QUYET DINH
#   InnoDB I/O ngau nhien (ke ca I/O NEN sau khi "active": buffer pool load,
#   purge, checkpoint, change-buffer merge) xuong loop/dm-crypt lam sap vold
#   -> reboot. Da kiem chung: cung thao tac start mariadb+php+nginx, DB tren DIA
#   thi reboot, DB tren TMPFS thi song (ghi 50k dong + serve HTTP 200, uptime lien tuc).
#   Ben vung: dong bo ("persist") RAM -> dia /var/lib/mysql.persist luc stop + dinh ky
#   (cron). Danh doi: mat du lieu ke tu lan persist cuoi neu mat dien dot ngot.
#   Tat bang HOSTVN_DB_TMPFS=no.
# ---------------------------------------------------------------
HOSTVN_DB_DIR="/var/lib/mysql"
HOSTVN_DB_PERSIST="/var/lib/mysql.persist"
HOSTVN_DB_TMPFS_SIZE="${HOSTVN_DB_TMPFS_SIZE:-1024M}"

_hostvn_db_tmpfs_enabled() {
    [ "${HOSTVN_ANDROID}" = "yes" ] && [ "${HOSTVN_DB_TMPFS:-yes}" = "yes" ]
}

# Copy nhe nhang GIUA dia va RAM. Tren Android, ngay ca doc/ghi ~100MB lien tuc
# tren storage ma hoa cung lam nghen vold -> reboot. Nen THROTTLE bang rsync --bwlimit
# (mac dinh 6MB/s) de vold co khe xu ly I/O; fallback tar theo tung phan neu khong co rsync.
HOSTVN_COPY_BWLIMIT="${HOSTVN_COPY_BWLIMIT:-6000}"   # KB/s
_hostvn_gentle_copy() {
    local src="$1" dst="$2"
    mkdir -p "$dst"
    if command -v rsync >/dev/null 2>&1; then
        rsync -a --bwlimit="${HOSTVN_COPY_BWLIMIT}" "$src"/ "$dst"/ 2>/dev/null
    else
        # Khong co rsync: copy tung muc con + sync + nghi ngan de gian I/O
        ( cd "$src" 2>/dev/null || return
          for f in * .[!.]*; do
              [ -e "$f" ] || continue
              cp -a "$f" "$dst"/ 2>/dev/null
              sync; sleep 0.3
          done )
    fi
    sync
}

# Gan tmpfs len datadir + seed tu ban persist tren dia (goi trong _svc mariadb start
# VA truoc khi cai mariadb-server de DB fresh sinh ra ngay tren tmpfs).
_hostvn_db_tmpfs_mount() {
    _hostvn_db_tmpfs_enabled || return 0
    mountpoint -q "${HOSTVN_DB_DIR}" 2>/dev/null && return 0   # da la tmpfs
    # Migration lan dau: neu datadir tren DIA da co du lieu ma persist chua co ->
    # RENAME (mv, tuc thi, KHONG copy) de tranh burst I/O copy disk->disk lam sap vold.
    if [ ! -d "${HOSTVN_DB_PERSIST}/mysql" ] && [ -d "${HOSTVN_DB_DIR}/mysql" ]; then
        rm -rf "${HOSTVN_DB_PERSIST}" 2>/dev/null
        mv "${HOSTVN_DB_DIR}" "${HOSTVN_DB_PERSIST}" 2>/dev/null
    fi
    mkdir -p "${HOSTVN_DB_DIR}" "${HOSTVN_DB_PERSIST}"
    mount -t tmpfs -o "size=${HOSTVN_DB_TMPFS_SIZE},mode=0755" tmpfs "${HOSTVN_DB_DIR}" 2>/dev/null || return 1
    chown mysql:mysql "${HOSTVN_DB_DIR}" 2>/dev/null
    # Seed RAM tu ban persist (chi DOC tu dia, GHI vao RAM) - copy nhe nhang
    [ -d "${HOSTVN_DB_PERSIST}/mysql" ] && _hostvn_gentle_copy "${HOSTVN_DB_PERSIST}" "${HOSTVN_DB_DIR}"
    return 0
}

# Dong bo datadir tmpfs -> dia (goi luc stop va dinh ky qua cron) - THROTTLE de tranh burst
_hostvn_db_persist() {
    _hostvn_db_tmpfs_enabled || return 0
    mountpoint -q "${HOSTVN_DB_DIR}" 2>/dev/null || return 0
    [ -d "${HOSTVN_DB_DIR}/mysql" ] || return 0
    _hostvn_gentle_copy "${HOSTVN_DB_DIR}" "${HOSTVN_DB_PERSIST}"
}

[ -z "${HOSTVN_INIT}" ] && _hostvn_detect_env
[ "${HOSTVN_ANDROID}" = "yes" ] && _hostvn_harden_android_io

# Thu muc luu danh sach service can auto-start (che do manual)
HOSTVN_AUTOSTART_DIR="/var/hostvn/autostart"
HOSTVN_RUN_DIR="/var/run/hostvn"

# ---------------------------------------------------------------
# _svc <action> <service>
#   action: start|stop|restart|reload|enable|disable|is-active|daemon-reload
# ---------------------------------------------------------------
_svc() {
    local action="$1" svc="$2"
    svc="${svc%.service}"

    if [ "${HOSTVN_INIT}" = "systemd" ]; then
        case "${action}" in
            daemon-reload) systemctl daemon-reload ;;
            *) systemctl "${action}" "${svc}" ;;
        esac
        return $?
    fi

    # ---------- Che do manual (khong systemd) ----------
    case "${action}" in
        daemon-reload) return 0 ;;
        enable) mkdir -p "${HOSTVN_AUTOSTART_DIR}"; : > "${HOSTVN_AUTOSTART_DIR}/${svc}"; return 0 ;;
        disable) rm -f "${HOSTVN_AUTOSTART_DIR}/${svc}"; return 0 ;;
    esac

    _svc_manual "${action}" "${svc}"
}

# Quan ly service truc tiep khi khong co systemd
_svc_manual() {
    local action="$1" svc="$2"
    mkdir -p "${HOSTVN_RUN_DIR}"

    case "${svc}" in
        nginx)
            case "${action}" in
                start)   [ -x /usr/sbin/nginx ] && /usr/sbin/nginx ;;
                stop)    /usr/sbin/nginx -s quit 2>/dev/null || pkill -x nginx ;;
                restart) /usr/sbin/nginx -s quit 2>/dev/null; pkill -x nginx 2>/dev/null; sleep 1; /usr/sbin/nginx ;;
                reload)  /usr/sbin/nginx -s reload 2>/dev/null || { /usr/sbin/nginx -s quit 2>/dev/null; sleep 1; /usr/sbin/nginx; } ;;
                is-active) pgrep -x nginx >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        php*-fpm)
            # QUAN TRONG: ten service HostVN la 'php8.4-fpm' NHUNG binary Debian la
            # 'php-fpm8.4' (dao vi tri). Neu dung nham '/usr/sbin/php8.4-fpm' -> khong ton
            # tai -> bin rong -> 'pkill -f ""' khop MOI tien trinh -> giet ca vold -> REBOOT.
            # Rut phien ban roi tao dung ten binary + pattern master; TUYET DOI khong pkill rong.
            local _ver="${svc#php}"; _ver="${_ver%-fpm}"          # php8.4-fpm -> 8.4
            local bin="/usr/sbin/php-fpm${_ver}"
            [ -x "${bin}" ] || bin="$(command -v "php-fpm${_ver}" 2>/dev/null)"
            # Match theo COMM 'php-fpm8.4' (pgrep/pkill -x). KHONG dung -f "php-fpm8.4: master"
            # vi cmdline that la 'php-fpm: master process (.../8.4/...conf)' -> khong khop ->
            # is-active bao sai + restart khong giet master cu (2 master trung). _pname
            # luon khac rong (dan xuat tu ten service) nen an toan, khong pkill rong.
            local _pname="php-fpm${_ver}"
            case "${action}" in
                start)   pgrep -x "${_pname}" >/dev/null 2>&1 || { [ -x "${bin}" ] && { mkdir -p /run/php; "${bin}"; }; } ;;
                stop)    pkill -x "${_pname}" 2>/dev/null ;;
                restart) pkill -x "${_pname}" 2>/dev/null; sleep 1; [ -x "${bin}" ] && { mkdir -p /run/php; "${bin}"; } ;;
                reload)  pkill -USR2 -x "${_pname}" 2>/dev/null || { pkill -x "${_pname}" 2>/dev/null; sleep 1; [ -x "${bin}" ] && { mkdir -p /run/php; "${bin}"; }; } ;;
                is-active) pgrep -x "${_pname}" >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        mariadb|mysql|mysqld)
            # Socket dung dung /run/mysqld/mysqld.sock cho khop [client] trong my.cnf
            # (config HostVN co [mysqld_safe] socket=/var/lib/mysql/mysql.sock -> neu khong
            #  ep, server va client lech socket -> moi lenh mysql khi cai deu that bai).
            local _sock=/run/mysqld/mysqld.sock
            # LD_PRELOAD eatmydata (chi tren Android, khi co lib) - khu fsync tranh reboot vold
            local _emd=""
            [ -n "${HOSTVN_EATMYDATA}" ] && _emd="LD_PRELOAD=${HOSTVN_EATMYDATA}"
            case "${action}" in
                start|restart)
                    if [ "${action}" = "restart" ]; then
                        mysqladmin --socket="${_sock}" shutdown 2>/dev/null || pkill -x mariadbd 2>/dev/null || pkill -x mysqld 2>/dev/null
                        sleep 2
                    fi
                    mkdir -p /run/mysqld; chown mysql:mysql /run/mysqld 2>/dev/null
                    # Android: gan datadir len tmpfs (RAM) + seed tu ban persist -> DB I/O
                    # khong cham vold. Phai chay TRUOC buoc init/khoi dong.
                    _hostvn_db_tmpfs_mount
                    # Khoi tao datadir neu trong (postinst co the khong chay duoc trong chroot khong systemd)
                    if [ ! -d /var/lib/mysql/mysql ]; then
                        env ${_emd} mariadb-install-db --user=mysql --datadir=/var/lib/mysql --auth-root-authentication-method=socket >/dev/null 2>&1 \
                            || env ${_emd} mysql_install_db --user=mysql --datadir=/var/lib/mysql >/dev/null 2>&1
                    fi
                    env ${_emd} setsid mysqld_safe --skip-syslog --socket="${_sock}" >/dev/null 2>&1 < /dev/null &
                    # Cho toi khi mariadb san sang (toi da 60s) truoc khi tra ve
                    local i=0
                    while [ $i -lt 60 ]; do
                        mysqladmin --socket="${_sock}" ping >/dev/null 2>&1 && break
                        sleep 1; i=$((i+1))
                    done ;;
                stop)
                    mysqladmin --socket="${_sock}" shutdown 2>/dev/null || pkill -x mariadbd || pkill -x mysqld
                    # Dong bo datadir RAM -> dia sau khi dung han (files nhat quan)
                    sleep 2; _hostvn_db_persist ;;
                reload)  mysqladmin --socket="${_sock}" reload 2>/dev/null || mysqladmin --socket="${_sock}" flush-privileges 2>/dev/null ;;
                is-active) { pgrep -x mariadbd >/dev/null || pgrep -x mysqld >/dev/null; } && echo active || { echo inactive; return 3; } ;;
            esac ;;

        redis*|redis-server)
            case "${action}" in
                start)   redis-server /etc/redis/redis.conf 2>/dev/null || redis-server --daemonize yes ;;
                stop)    redis-cli shutdown nosave 2>/dev/null || pkill -x redis-server ;;
                restart) { redis-cli shutdown nosave 2>/dev/null || pkill -x redis-server 2>/dev/null; }; sleep 1; redis-server /etc/redis/redis.conf 2>/dev/null || redis-server --daemonize yes ;;
                reload)  : ;;
                is-active) pgrep -x redis-server >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        memcached)
            # KHONG dung '-d' (daemonize cua memcached khong song trong container/chroot -
            # tien trinh thoat sau khi fork). Chay foreground + setsid de nen (nhu cac service khac).
            case "${action}" in
                start)   [ -x /usr/bin/memcached ] && setsid /usr/bin/memcached -u nobody -m 64 -l 127.0.0.1 </dev/null >/dev/null 2>&1 & ;;
                stop)    pkill -x memcached ;;
                restart) pkill -x memcached 2>/dev/null; sleep 1; setsid /usr/bin/memcached -u nobody -m 64 -l 127.0.0.1 </dev/null >/dev/null 2>&1 & ;;
                is-active) pgrep -x memcached >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        fail2ban)
            # Trong chroot (khong systemd) /var/run KHONG duoc don khi boot, nen sau khi
            # may/container tat dot ngot thi fail2ban.sock + .pid cu con sot lai va
            # 'fail2ban-client start' se tu choi khoi dong. Don socket mo coi truoc khi start.
            _f2b_start() {
                if fail2ban-client ping >/dev/null 2>&1; then
                    return 0        # dang chay that -> khong lam gi
                fi
                rm -f /var/run/fail2ban/fail2ban.sock /var/run/fail2ban/fail2ban.pid 2>/dev/null
                mkdir -p /var/run/fail2ban 2>/dev/null
                fail2ban-client -x start 2>/dev/null
            }
            case "${action}" in
                start)   _f2b_start ;;
                stop)    fail2ban-client stop 2>/dev/null ;;
                restart) fail2ban-client reload 2>/dev/null || { fail2ban-client stop 2>/dev/null; sleep 1; _f2b_start; } ;;
                reload)  fail2ban-client reload 2>/dev/null ;;
                is-active) fail2ban-client ping >/dev/null 2>&1 && echo active || { echo inactive; return 3; } ;;
            esac ;;

        cron|crond)
            case "${action}" in
                start|restart) pkill -x cron 2>/dev/null; sleep 1; cron 2>/dev/null || /usr/sbin/cron 2>/dev/null ;;
                stop)    pkill -x cron ;;
                is-active) pgrep -x cron >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        cloudflared)
            # cloudflared chay bang tunnel token. Che do manual (khong systemd, vd Android):
            # doc token tu file /etc/cloudflared/hostvn-token (do menu tunnel/setup luu) neu
            # bien TUNNEL_TOKEN chua duoc set -> khoi dong 'cloudflared tunnel run --token'.
            local _cftok="${TUNNEL_TOKEN:-$(cat /etc/cloudflared/hostvn-token 2>/dev/null)}"
            case "${action}" in
                start|restart)
                    pkill -x cloudflared 2>/dev/null; sleep 1
                    [ -n "${_cftok}" ] && setsid cloudflared tunnel run --token "${_cftok}" >/dev/null 2>&1 < /dev/null &
                    ;;
                stop)    pkill -x cloudflared ;;
                is-active) pgrep -x cloudflared >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        hostvn-telegram-bot)
            # Bot Telegram (che do manual, khong systemd). Uu tien ban Python (venv),
            # fallback bot.sh (bash) neu chua dung venv.
            local _botdir=/var/hostvn/menu/telegram_bot
            local _py="${_botdir}/venv/bin/python"
            local _botpy="${_botdir}/bot.py"
            local _botsh="${_botdir}/bot.sh"
            case "${action}" in
                start|restart)
                    pkill -f "telegram_bot/bot.py" 2>/dev/null
                    pkill -f "telegram_bot/bot.sh" 2>/dev/null
                    sleep 1
                    if [ -x "${_py}" ] && [ -f "${_botpy}" ]; then
                        ( cd "${_botdir}" && setsid "${_py}" "${_botpy}" >/root/tgbot.log 2>&1 < /dev/null & )
                    elif [ -f "${_botsh}" ]; then
                        setsid /bin/bash "${_botsh}" >/dev/null 2>&1 < /dev/null &
                    fi
                    ;;
                stop)
                    pkill -f "telegram_bot/bot.py" 2>/dev/null
                    pkill -f "telegram_bot/bot.sh" 2>/dev/null
                    ;;
                is-active)
                    { pgrep -f "telegram_bot/bot.py" >/dev/null || pgrep -f "telegram_bot/bot.sh" >/dev/null; } \
                        && echo active || { echo inactive; return 3; }
                    ;;
            esac ;;

        supervisor|supervisord)
            case "${action}" in
                start|restart) pkill -x supervisord 2>/dev/null; sleep 1; supervisord -c /etc/supervisor/supervisord.conf 2>/dev/null ;;
                stop)    pkill -x supervisord ;;
                is-active) pgrep -x supervisord >/dev/null && echo active || { echo inactive; return 3; } ;;
            esac ;;

        ufw|clamav-freshclam|clamav-daemon)
            # Cac service khong quan trong / khong kha dung trong chroot: bo qua nhe nhang
            case "${action}" in
                is-active) echo inactive; return 3 ;;
                *) return 0 ;;
            esac ;;

        *)
            # Fallback: thu 'service' neu co init.d script
            if command -v service >/dev/null 2>&1; then
                service "${svc}" "${action}" 2>/dev/null && return 0
            fi
            return 0 ;;
    esac
}

# Tien ich: kiem tra service dang chay (thay cho '_svc is-active --quiet')
_svc_active() {
    [ "$(_svc is-active "$1" 2>/dev/null)" = "active" ]
}

# So luong job build an toan: gioi han tren Android/thiet bi RAM thap
# (build -j8 tren dien thoai co the gay OOM/qua nhiet -> reboot)
_build_jobs() {
    local cores mem_kb j
    cores=$(nproc 2>/dev/null || echo 1)
    mem_kb=$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 1000000)
    j="${cores}"
    # Android/container: gioi han toi da 2 job cho on dinh
    if [ "${HOSTVN_ANDROID}" = "yes" ]; then
        j=2
    fi
    # Moi job ~1GB RAM: khong vuot qua RAM/1GB
    local mem_cap=$(( mem_kb / 1048576 ))
    [ "${mem_cap}" -lt 1 ] && mem_cap=1
    [ "${j}" -gt "${mem_cap}" ] && j="${mem_cap}"
    [ "${j}" -lt 1 ] && j=1
    echo "${j}"
}
